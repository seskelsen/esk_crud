# Configurações para testes
# Usa MongoDB local para testes

FLASK_APP=api/app.py
FLASK_ENV=testing

# MongoDB local para testes (não requer autenticação por padrão)
MONGO_URI=mongodb://localhost:27017/eskcrud_test

# Chaves de segurança para testes
SECRET_KEY=test-secret-key
JWT_SECRET_KEY=test-jwt-secret-key
WTF_CSRF_SECRET_KEY=test-csrf-secret-key
